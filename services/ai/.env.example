# Service binds to loopback only; the Node gateway is its sole caller.
AI_HOST=127.0.0.1
AI_PORT=8792

# Which LLM backend powers AskAI + sentiment: "openai" (now) or "anthropic"
# (later). Flip this one value to switch — no code change, no redeploy of logic.
AI_PROVIDER=openai

# --- OpenAI (active while AI_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_SENTIMENT_MODEL=gpt-4o-mini

# --- Anthropic (used when you flip AI_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_SENTIMENT_MODEL=claude-haiku-4-5

# Master key for encrypting broker API keys at rest (generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_MASTER_KEY=

# --- Read-only Alpaca connector (optional) ---
# Leave blank to keep Account Aggregation on demo data. Get keys at
# https://alpaca.markets (a free PAPER account works). Use read-only keys.
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Paper: https://paper-api.alpaca.markets   Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Dedicated DB + role on the existing Postgres instance (see deploy/README.md).
DATABASE_URL=postgresql://levant:<password>@127.0.0.1:5432/levant
# Dedicated logical Redis DB index so we don't collide with other apps.
REDIS_URL=redis://127.0.0.1:6379/3
