# Gateway binds to loopback only; the reverse proxy is the public face.
HOST=127.0.0.1
PORT=8791

# Upstream Python AI/aggregation service (also loopback).
AI_SERVICE_URL=http://127.0.0.1:8792

# Comma-separated allowed origins for CORS in dev.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# JWT signing secret (generate a long random value in production:
#   openssl rand -hex 32 )
JWT_SECRET=change-me-in-production

# Dedicated DB + role on the existing Postgres instance (see deploy/README.md).
DATABASE_URL=postgresql://levant:<password>@127.0.0.1:5432/levant
REDIS_URL=redis://127.0.0.1:6379/3
